{
  "name": "grove",
  "version": "1.0.0",
  "description": "A component-first Shopify theme framework engineered for AI agent development, token efficiency, and theme store quality.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch & shopify theme dev --path shopify --environment development",
    "build": "vite build",
    "build:preset": "node scripts/generate-tokens.js --preset $npm_config_preset && vite build --mode $npm_config_preset",
    "lint": "pnpm lint:js && pnpm lint:scss && pnpm lint:liquid",
    "lint:js": "eslint 'src/**/*.{js,vue}'",
    "lint:scss": "stylelint 'src/**/*.scss'",
    "lint:liquid": "prettier --check 'src/**/*.liquid'",
    "format": "prettier --write 'src/**/*.{js,json,scss,vue,liquid}'",
    "validate-schemas": "node scripts/validate-schemas.js",
    "schema-diff": "node scripts/schema-diff.js",
    "generate-tokens": "node scripts/generate-tokens.js",
    "theme-check": "node node_modules/@shopify/theme-check-node/dist/cli.js",
    "new-component": "node scripts/new-component.js",
    "render": "node scripts/render-fixture.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@shopify/prettier-plugin-liquid": "^1.5.0",
    "@shopify/theme-check-node": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "dart-sass": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-vue": "^9.0.0",
    "glob": "^13.0.6",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.70.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-order": "^6.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "liquidjs": "^10.0.0"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.liquid": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.schema.json": [
      "node scripts/validate-schemas.js --staged"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
