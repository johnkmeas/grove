{
  "_version": "2.0.0",
  "name": "Hero",
  "tag": "section",
  "class": "grove-hero",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" },
        { "value": "color", "label": "Colour background" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background colour",
      "default": "linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 100%)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top centre" },
        { "value": "top-right", "label": "Top right" },
        { "value": "middle-left", "label": "Middle left" },
        { "value": "middle-center", "label": "Middle centre" },
        { "value": "middle-right", "label": "Middle right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom centre" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "default": "middle-center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small (400px)" },
        { "value": "medium", "label": "Medium (560px)" },
        { "value": "large", "label": "Large (720px)" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    { "type": "@theme" },
    { "type": "heading" },
    { "type": "text" },
    { "type": "button" }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "media_type": "image",
        "content_position": "middle-center",
        "content_alignment": "center",
        "height": "medium"
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": "Discover something new",
            "heading_tag": "h2",
            "size": "xl"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "<p>Shop our latest collection</p>",
            "size": "md"
          }
        },
        {
          "type": "button",
          "settings": {
            "label": "Shop now",
            "style": "primary"
          }
        }
      ]
    }
  ]
}
