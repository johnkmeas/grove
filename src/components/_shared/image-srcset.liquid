{% comment %}
  image-srcset.liquid
  Renders a responsive <img> using Shopify's image_url + image_tag filters.
  Automatically generates srcset, selects best format (AVIF/WebP), and sets
  width/height attributes to prevent layout shift.

  Usage:
    {% render 'image-srcset',
      image: section.settings.image,
      class: 'hero__image',
      sizes: '100vw',
      loading: 'eager',
      fetchpriority: 'high'
    %}

  Parameters:
    image         — Shopify image object (required)
    class         — CSS class string (optional)
    sizes         — sizes attribute value (optional, default: '100vw')
    loading       — 'lazy' | 'eager' (optional, default: 'lazy')
    fetchpriority — 'high' | 'low' | 'auto' (optional, default: 'auto')
    alt           — alt text override (optional, falls back to image.alt)
    widths        — comma-separated candidate widths (optional,
                    default: '375, 550, 750, 1100, 1500, 1780, 2000')
    max_width     — largest width to request from CDN (optional, default: 2000)
{% endcomment %}

{%- liquid
  assign img_sizes = sizes | default: '100vw'
  assign img_loading = loading | default: 'lazy'
  assign img_fetchpriority = fetchpriority | default: 'auto'
  assign img_alt = alt | default: image.alt
  assign img_class = class | default: ''
  assign img_widths = widths | default: '375, 550, 750, 1100, 1500, 1780, 2000'
  assign img_max_width = max_width | default: 2000
-%}

{%- if image != blank -%}
  {{- image
    | image_url: width: img_max_width
    | image_tag:
      widths: img_widths,
      sizes: img_sizes,
      loading: img_loading,
      fetchpriority: img_fetchpriority,
      class: img_class,
      alt: img_alt
  -}}
{%- endif -%}
