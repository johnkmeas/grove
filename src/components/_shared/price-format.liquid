{% comment %}
  price-format.liquid
  Renders a formatted price with currency symbol, sale handling, and unit pricing.

  Usage:
    {% render 'price-format',
      product: product,
      show_compare: true,
      show_unit_price: true
    %}

  Parameters:
    product          — Shopify product object (required)
    variant          — specific variant to show price for (optional, defaults to selected/first available)
    show_compare     — boolean, show compare_at_price if on sale (optional, default: true)
    show_unit_price  — boolean, show unit price if available (optional, default: false)
    class            — wrapper CSS class (optional)
{% endcomment %}

{%- liquid
  assign price_class = class | default: 'price'
  assign show_compare_at = show_compare | default: true
  assign show_unit = show_unit_price | default: false

  if variant
    assign active_variant = variant
  else
    assign active_variant = product.selected_or_first_available_variant
  endif

  assign current_price = active_variant.price
  assign compare_price = active_variant.compare_at_price
  assign on_sale = false
  if compare_price > current_price
    assign on_sale = true
  endif
-%}

<div class="{{ price_class }}{% if on_sale %} {{ price_class }}--on-sale{% endif %}">
  {%- if on_sale and show_compare_at -%}
    <span class="{{ price_class }}__compare" aria-label="{{ 'products.price.regular_price' | t }}: {{ compare_price | money }}">
      <s>{{ compare_price | money }}</s>
    </span>
  {%- endif -%}

  <span
    class="{{ price_class }}__current"
    {% if on_sale %}aria-label="{{ 'products.price.sale_price' | t }}: {{ current_price | money }}"{% endif %}
  >
    {{ current_price | money }}
  </span>

  {%- if show_unit and active_variant.unit_price_measurement -%}
    <span class="{{ price_class }}__unit" aria-label="{{ 'products.price.unit_price' | t }}">
      {{ active_variant.unit_price | money }}
      <span aria-hidden="true">/</span>
      <span class="visually-hidden">{{ 'products.price.unit_price_separator' | t }}</span>
      {%- if active_variant.unit_price_measurement.reference_value != 1 -%}
        {{- active_variant.unit_price_measurement.reference_value -}}
      {%- endif -%}
      {{ active_variant.unit_price_measurement.reference_unit }}
    </span>
  {%- endif -%}
</div>
