{
  "extends": ["stylelint-config-standard-scss"],
  "plugins": ["stylelint-order"],
  "rules": {
    "order/properties-alphabetical-order": null,
    "order/order": [
      "custom-properties",
      "dollar-variables",
      "at-rules",
      "declarations",
      "rules"
    ],
    "order/properties-order": [
      "content",
      "position",
      "inset",
      "top",
      "right",
      "bottom",
      "left",
      "z-index",
      "display",
      "flex",
      "flex-direction",
      "flex-wrap",
      "flex-flow",
      "align-items",
      "align-self",
      "justify-content",
      "justify-self",
      "gap",
      "grid",
      "grid-template",
      "grid-area",
      "grid-column",
      "grid-row",
      "width",
      "min-width",
      "max-width",
      "height",
      "min-height",
      "max-height",
      "overflow",
      "overflow-x",
      "overflow-y",
      "margin",
      "margin-top",
      "margin-right",
      "margin-bottom",
      "margin-left",
      "padding",
      "padding-top",
      "padding-right",
      "padding-bottom",
      "padding-left",
      "border",
      "border-width",
      "border-style",
      "border-color",
      "border-radius",
      "outline",
      "outline-offset",
      "background",
      "background-color",
      "background-image",
      "background-size",
      "background-position",
      "color",
      "font",
      "font-family",
      "font-size",
      "font-weight",
      "font-style",
      "line-height",
      "letter-spacing",
      "text-align",
      "text-decoration",
      "text-transform",
      "white-space",
      "opacity",
      "visibility",
      "cursor",
      "pointer-events",
      "transition",
      "transform",
      "animation"
    ],
    "scss/at-rule-no-unknown": true,
    "scss/no-global-function-names": null,
    "selector-class-pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*(__[a-z][a-z0-9]*(-[a-z0-9]+)*)?(--[a-z][a-z0-9]*(-[a-z0-9]+)*)?$",
    "comment-empty-line-before": null,
    "no-descending-specificity": null,
    "scss/dollar-variable-pattern": "^[a-z][a-z0-9-]*$",
    "custom-property-pattern": "^grove-.+$",
    "color-no-invalid-hex": true,
    "unit-no-unknown": true,
    "property-no-unknown": true,
    "declaration-block-no-duplicate-properties": true,
    "max-nesting-depth": 3
  }
}
